# GitHub Configuration
# Your GitHub repository in format username/repo-name
GITHUB_REPO=username/work-contributions

# Your GitHub Personal Access Token (with repo permissions)
# Get it from: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Author Information
# Your personal name for commit authorship
AUTHOR_NAME="Your Name"

# Your personal email (must be verified on GitHub)
AUTHOR_EMAIL=your.personal@gmail.com

# Optional: Path to projects folder (scanned recursively)
# If not specified, uses current directory
PROJECTS_DIR=~/work-projects

# Optional: Filter commits by email
# Only commits from this email will be imported
FILTER_EMAIL=your.work@company.com

# Optional: Filter commits by date range (format: YYYY-MM-DD)
# Only commits from SINCE_DATE onwards will be imported
SINCE_DATE=2024-01-01
# Only commits up to UNTIL_DATE will be imported
UNTIL_DATE=2024-12-31

# Optional: Preview what would be imported without creating or pushing anything
# DRY_RUN=true
